{
  "expo": {
    "name": "Horizen Gym",
    "slug": "gymapp",
    "scheme": "gymapp",
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#e11d48",
      "resizeMode": "contain"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Horizen to access your photos to set your profile picture."
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.anonymous.gymapp",
      "runtimeVersion": "1.0.0"
    },
    "extra": {
      "eas": {
        "projectId": "637fafbc-8e16-4b96-b29e-11783abd17dc"
      }
    },
    "owner": "brendindp",
    "updates": {
      "url": "https://u.expo.dev/637fafbc-8e16-4b96-b29e-11783abd17dc"
    },
    "android": {
      "runtimeVersion": {
        "policy": "appVersion"
      }
    }
  }
}

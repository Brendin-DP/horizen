# API URL for the Express backend. Required when running on a physical device.
# Leave unset for iOS Simulator (localhost works).
# For physical device: use your Mac's LAN IP, e.g. http://192.168.1.5:3001
# For Android emulator: use http://10.0.2.2:3001
# EXPO_PUBLIC_API_URL=http://192.168.1.5:3001
